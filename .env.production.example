# Production environment
NODE_ENV=production
PORT=3000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/salud-de-una

JWT_SECRET=replace-with-strong-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-another-strong-secret-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_MAX_ACTIVE_SESSIONS=3

# Replace with your real frontend URLs
CORS_ORIGINS_PATIENT=https://patients.example.com
CORS_ORIGINS_STAFF=https://staff.example.com

# Optional bootstrap admin
ENABLE_BOOTSTRAP_ADMIN=false
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=AdminP@ss1
BOOTSTRAP_ADMIN_FIRST_NAME=Admin
BOOTSTRAP_ADMIN_LAST_NAME=System

# Redis Cloud / outbox / distributed throttling
REDIS_URL=rediss://default:<password>@<host>:6379
REDIS_KEY_PREFIX=salud-de-una-prod
OUTBOX_DISPATCH_INTERVAL_MS=1000

# Gemini via Google AI Studio
AI_ENABLED=true
AI_PROVIDER=gemini
GEMINI_API_KEY=<google-ai-studio-api-key>
GEMINI_MODEL=gemini-2.5-flash
