# Development environment
NODE_ENV=development
APP_RUNTIME_ROLE=all
PORT=3000
MONGODB_URI=mongodb://localhost:27017/salud-de-una

JWT_SECRET=change-this-secret-with-at-least-32-characters
JWT_REFRESH_SECRET=change-this-refresh-secret-with-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_MAX_ACTIVE_SESSIONS=3

# Frontend origins for local development
CORS_ORIGINS_PATIENT=http://localhost:5173,http://localhost:8081,http://127.0.0.1:8081
CORS_ORIGINS_STAFF=http://localhost:5174

# Optional bootstrap admin
ENABLE_BOOTSTRAP_ADMIN=false
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=AdminP@ss1
BOOTSTRAP_ADMIN_FIRST_NAME=Admin
BOOTSTRAP_ADMIN_LAST_NAME=System

# Redis Cloud / outbox / distributed throttling
REDIS_URL=redis://default:<password>@<host>:6379
REDIS_KEY_PREFIX=salud-de-una-dev
OUTBOX_DISPATCH_INTERVAL_MS=1000

# Gemini via Google AI Studio
AI_ENABLED=false
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

RAG_SUMMARY_ENABLED=false
RAG_TRIAGE_ENABLED=false
RAG_PATIENT_EVIDENCE_ENABLED=false
RAG_TOP_K=8
RAG_MAX_CONTEXT_CHUNKS=10
RAG_EMBEDDING_DIMENSIONS=768
RAG_VECTOR_INDEX_NAME=salud_de_una_knowledge_chunks_vector_v1

OTEL_ENABLED=false
OTEL_SERVICE_NAME=salud-de-una-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
