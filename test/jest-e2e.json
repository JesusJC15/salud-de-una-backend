{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "testTimeout": 120000,
  "setupFilesAfterEnv": ["<rootDir>/jest.setup.ts"],
  "silent": true,
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^jwks-rsa$": "<rootDir>/mocks/jwks-rsa.js"
  }
}
