{
  "name": "salud-de-una",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:prod:api": "node dist/main",
    "start:prod:worker": "node dist/main",
    "typecheck": "tsc --noEmit",
    "validate:env": "node scripts/validate-env.js",
    "smoke:startup": "node scripts/smoke-startup.js",
    "verify:production": "node docker/verify-production.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "export:openapi": "NODE_ENV=development npm run start:dev",
    "test": "node scripts/run-jest.js",
    "test:watch": "node scripts/run-jest.js --watch",
    "test:cov": "node scripts/run-jest.js --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "node scripts/run-jest.js --config ./test/jest-e2e.json --runInBand",
    "test:e2e:auth": "node scripts/run-jest.js --config ./test/jest-e2e.json --runInBand test/e2e/auth",
    "test:e2e:admin": "node scripts/run-jest.js --config ./test/jest-e2e.json --runInBand test/e2e/admin",
    "test:e2e:doctors": "node scripts/run-jest.js --config ./test/jest-e2e.json --runInBand test/e2e/doctors",
    "test:e2e:patients": "node scripts/run-jest.js --config ./test/jest-e2e.json --runInBand test/e2e/patients",
    "test:e2e:triage": "node scripts/run-jest.js --config ./test/jest-e2e.json --runInBand test/e2e/triage",
    "test:e2e:consultations": "node scripts/run-jest.js --config ./test/jest-e2e.json --runInBand test/e2e/consultations",
    "test:e2e:notifications": "node scripts/run-jest.js --config ./test/jest-e2e.json --runInBand test/e2e/notifications",
    "test:e2e:dashboard": "node scripts/run-jest.js --config ./test/jest-e2e.json --runInBand test/e2e/dashboard",
    "test:e2e:clinical-ai": "node scripts/run-jest.js --config ./test/jest-e2e.json --runInBand test/e2e/clinical-ai",
    "test:e2e:system": "node scripts/run-jest.js --config ./test/jest-e2e.json --runInBand test/e2e/system",
    "test:e2e:chat": "node scripts/run-jest.js --config ./test/jest-e2e.json --runInBand test/e2e/chat",
    "test:e2e:followups": "node scripts/run-jest.js --config ./test/jest-e2e.json --runInBand test/e2e/followups"
  },
  "dependencies": {
    "@google/genai": "^2.2.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.2.1",
    "jose": "^6.2.3",
    "jwks-rsa": "^4.0.1",
    "mongoose": "^9.6.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.1.0",
    "prettier": "^3.8.3",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^jwks-rsa$": "<rootDir>/../test/mocks/jwks-rsa.js"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/*.dto.ts",
      "!**/*.schema.ts",
      "!**/provisioning.service.ts",
      "!**/chat.gateway.ts",
      "!**/jwt-legacy.strategy.ts",
      "!**/jwt-provision.strategy.ts"
    ],
    "coverageDirectory": "../coverage",
    "setupFiles": [
      "<rootDir>/../test/jest.env.ts"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/../test/jest.setup.ts"
    ],
    "silent": true,
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 80,
        "functions": 80,
        "lines": 80
      }
    }
  },
  "overrides": {
    "protobufjs": "8.2.0"
  }
}
