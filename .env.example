# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ───────────────────────────────────────────────────────────────────
# Required. Use MongoDB Atlas connection string in production.
MONGODB_URI=mongodb://localhost:27017/salud-de-una

# ── Auth0 (Identity Provider) ─────────────────────────────────────────────────
# Required for production. Get these from your Auth0 dashboard.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.salud-de-una.com

# Auth0 Management API (Machine to Machine) — used for user provisioning only.
# Never expose these to clients. Store in a secrets manager in production.
AUTH0_M2M_CLIENT_ID=your-m2m-client-id
AUTH0_M2M_CLIENT_SECRET=your-m2m-client-secret

# Auth0 Role IDs — copy from Auth0 dashboard: User Management → Roles → click role → copy ID
AUTH0_ROLE_ID_PATIENT=rol_xxxxxxxxxxxxxx
AUTH0_ROLE_ID_DOCTOR=rol_xxxxxxxxxxxxxx
AUTH0_ROLE_ID_ADMIN=rol_xxxxxxxxxxxxxx

# ── Legacy JWT — deprecated ───────────────────────────────────────────────────
# Keep during the Auth0 cutover window (~90 days). Remove after all clients migrate.
# Must be at least 32 characters.
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string-32-chars
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Session ────────────────────────────────────────────────────────────────────
REFRESH_MAX_ACTIVE_SESSIONS=3

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Empty = allow all (not safe for production).
CORS_ORIGINS_PATIENT=http://localhost:8081
CORS_ORIGINS_STAFF=http://localhost:3001

# ── Bootstrap Admin ───────────────────────────────────────────────────────────
# One-time setup only. Use a secrets manager — never commit real credentials.
# Set ENABLE_BOOTSTRAP_ADMIN=true only on first deployment.
ENABLE_BOOTSTRAP_ADMIN=false
BOOTSTRAP_ADMIN_EMAIL=admin@salud-de-una.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_FIRST_NAME=Admin
BOOTSTRAP_ADMIN_LAST_NAME=SaludDeUna

# ── Redis ─────────────────────────────────────────────────────────────────────
# Optional. If not set, falls back to in-memory throttling and metrics.
# Use Redis Cloud URL in production: redis://default:password@host:port
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=salud-de-una
OUTBOX_DISPATCH_INTERVAL_MS=1000

# ── AI ────────────────────────────────────────────────────────────────────────
AI_ENABLED=false
AI_PROVIDER=gemini
# Required when AI_ENABLED=true
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── Auth0 Migration ───────────────────────────────────────────────────────────
# Shared secret for the Auth0 Custom DB migration endpoint.
# Generate a random string: openssl rand -hex 32
AUTH0_MIGRATION_KEY=your-migration-secret-key
